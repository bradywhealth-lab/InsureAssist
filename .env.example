# ── InsureAssist Mock API — environment variables ──────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored and will NEVER be committed.

# Port the server listens on (default: 3001)
PORT=3001

# API key required on all protected routes.
# Set to any strong random string. Leave blank to disable auth (dev only).
# Generate one: openssl rand -hex 32
API_KEY=

# Anthropic API key — enables real Claude AI responses.
# Get one at: https://console.anthropic.com
# Leave blank to use built-in mock responses (no AI calls made).
ANTHROPIC_API_KEY=

# Allowed CORS origins (comma-separated). Defaults to * (all origins).
# Example: http://localhost:3000,https://app.yourdomain.com
CORS_ORIGIN=
